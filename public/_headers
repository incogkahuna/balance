# Cache static assets aggressively (Vite hashes filenames so cache-bust is automatic),
# but never cache index.html — we always want the latest entry point so a deploy
# is picked up on the next request.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate

# Baseline security headers — tighten as needed.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=()
