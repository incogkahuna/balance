# ─── Balance environment variables ─────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit secrets.
#
# Variables prefixed with VITE_ are exposed to the browser at build time.
# Anything else stays server-side (Supabase Edge Functions, scripts, etc.).
# ───────────────────────────────────────────────────────────────────────────

# ─── Supabase (browser) ────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<id>/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Supabase (server / scripts only — never prefix with VITE_) ────────────
# Service role key — full DB access, used only by migration scripts and
# Edge Functions. NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local Supabase CLI access token (for `supabase` CLI commands)
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# ─── Phase 4: Intake automation (Edge Function env, set in Supabase dashboard) ─
# These are NOT loaded by Vite — they're set as Edge Function secrets via:
#   supabase secrets set OPENAI_API_KEY=...
# Listed here for documentation only.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Phase 4c: Inbound email (set when Cloudflare Email Routing is wired) ──
# EMAIL_WEBHOOK_SIGNING_SECRET=

# ─── Phase 7: Google Calendar (set in Supabase Edge Function secrets) ─────
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Phase 8: Slack (set in Supabase Edge Function secrets) ───────────────
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=
